# 环境变量配置

# ========== 必填配置 ==========

# 豆包（火山引擎）API Key
# 获取地址：https://console.volcengine.com/ark → API Key 管理
# 注册即送 50 万 tokens 体验额度
ARK_API_KEY=你的火山引擎API Key

# ========== 可选配置 ==========

# 服务端口（默认 3000）
PORT=3000

# 豆包 API 地址（默认火山引擎）
ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 默认模型
DEFAULT_MODEL=doubao-1.5-32k

# 身份校验密钥（App端需要传这个 Key 才能调用你的后端）
# 建议设置一个复杂的随机字符串
AUTH_TOKEN=your-secret-auth-token-here

# 调用频率限制（每个IP每分钟最多请求次数，默认 20）
RATE_LIMIT_PER_MINUTE=20

# 单次最大 tokens
MAX_TOKENS=2048
